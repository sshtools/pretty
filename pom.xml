										<install4j.jaulAppId>${install4j.jaulAppId}</install4j.jaulAppId>
										<install4j.jaulUpdaterId>${install4j.jaulUpdaterId}</install4j.jaulUpdaterId>
									</variables>
									<release>${product.version}-${build.number}</release>
