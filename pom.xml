									${project.build.directory}/media-windows/updates.xml</input>
								<input>
									${project.build.directory}/media-linux/updates.xml</input>
							</inputs>
							<output>${project.build.directory}/media/updates.xml</output>
						</configuration>
					</plugin>
				</plugins>
			</build>
		</profile>
